# =============================================================================
# MAGI — env schema. Copy to `.env` and edit. NEVER commit `.env`.
#
# Defaults for everything below live in `magi/node/__init__.py` or in
# `docker-compose.yml` (via `${VAR:-default}`). Override here when
# you need to. Nothing in this file is strictly required for C0.
# =============================================================================

# Parent dir for all MAGI containers' working data on the host.
# Each container gets its own subdirectory:
#   Adam : ${MAGI_WORKSPACE_DIR}/Adam     → bind-mounted to /workspace inside
#   EVE  : ${MAGI_WORKSPACE_DIR}/eve-<id> → (lands in C6)
# SQLite file lives at /workspace/state/magi.db inside the container.
MAGI_WORKSPACE_DIR=./workspace