# =============================================================================
# MAGI — environment variables for local / docker-compose deployment.
# Copy to `.env` and edit. NEVER commit `.env`.
# =============================================================================

# ---- Role preset ------------------------------------------------------------
# Adam and EVE are not two node types — they are the same node, with
# different config presets:
#   adam — permission scope = enterprise. Default channel: webui.
#   eve  — permission scope = personal.   Default channel: telegram.
# Every underlying axis (channels, state backend, LLM, peers) is
# overridable independently; this only sets defaults + scope.
MAGI_NODE_ROLE=adam

# ---- Channels (comma-separated) ---------------------------------------------
# Any node can mount any subset of channels. Overrides the role default.
# MAGI_CHANNELS=webui,telegram

# ---- Shared secret ---------------------------------------------------------
# Auth between nodes (Adam RPC, EVE ingest, etc.).
# MUST be set in production; the dev compose file generates one if absent.
MAGI_SHARED_SECRET=change-me-to-a-long-random-string

# ---- Adam RPC peer ---------------------------------------------------------
# Any node that calls Adam (audit push, config pull, heartbeat) needs this.
# Always read regardless of role / channels.
MAGI_ADAM_URL=http://adam:8000

# ---- State backend ---------------------------------------------------------
# Which persistent store to use. Independent of role.
#   postgres — Postgres + pgvector (typically shared, system of record)
#   sqlite   — local SQLite + sqlite-vec (typically per-node)
#   auto     — postgres if DATABASE_URL is set, else sqlite
MAGI_STATE_BACKEND=auto

# ---- Postgres (when state_backend = postgres / auto-with-DATABASE_URL) -----
DATABASE_URL=postgresql+psycopg://magi:magi@postgres:5432/magi

# ---- Common ----------------------------------------------------------------
MAGI_HOST=0.0.0.0
MAGI_PORT=8000
MAGI_LOG_LEVEL=info
MAGI_RELOAD=0

# ---- Telegram channel (set when "telegram" is in MAGI_CHANNELS) ------------
MAGI_EMPLOYEE_ID=
MAGI_BOT_TOKEN=
# Local working state (sqlite file location for the Telegram channel).
MAGI_STATE_DIR=/var/lib/magi/eve

# ---- LLM providers ---------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
MAGI_LLM_PROVIDER=anthropic
MAGI_LLM_MODEL=claude-sonnet-4-6